# PostgreSQL connection string (Supabase pooler recommended)
# IMPORTANT: do NOT append ?sslmode=require — causes a TLS certificate
# error with pg 8.x. SSL is handled explicitly in code instead.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# App
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"